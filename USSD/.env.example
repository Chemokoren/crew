# AMY MIS USSD Gateway — Environment Variables
# Copy to .env and fill in actual values

# Server
PORT=8090
ENVIRONMENT=development  # development | staging | production

# Backend API (AMY MIS core)
BACKEND_BASE_URL=http://localhost:8080
BACKEND_API_KEY=
BACKEND_TIMEOUT_MS=1500

# Redis (session store)
REDIS_URL=redis://localhost:6379/1
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=20

# Session Management
SESSION_TTL_SECONDS=180
SESSION_PREFIX=ussd:session:

# Telco Gateway
PRIMARY_GATEWAY=africastalking
AT_API_KEY=
AT_USERNAME=sandbox
AT_SHORTCODE=
AT_BASE_URL=https://api.africastalking.com/version1

# Rate Limiting
RATE_LIMIT_PER_MSISDN=30
RATE_LIMIT_GLOBAL_RPM=50000

# Circuit Breaker
CB_MAX_FAILURES=5
CB_TIMEOUT_SECONDS=30

# Observability
METRICS_ENABLED=true
TRACING_ENABLED=true
LOG_LEVEL=info

# Idempotency
IDEMPOTENCY_TTL_SECONDS=300

# Security
INPUT_MAX_LENGTH=160
SANITIZE_INPUT=true
PIN_MASKING_ENABLED=true

# Localization
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,sw

# CORS (for USSD simulator UI)
CORS_ALLOWED_ORIGINS=*
