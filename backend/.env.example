# AMY MIS — Environment Variables
# Copy to .env and fill in actual values

# Server
PORT=8080
ENVIRONMENT=development  # development | staging | production

# Database (PostgreSQL)
DATABASE_URL=postgres://jp:jp%23%23%23%23@localhost:5432/amymis?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_DAYS=7

# Service API Key (for trusted internal services like USSD gateway)
SERVICE_API_KEY=ussd-service-key-change-in-production

# MinIO (S3-compatible file storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=amy-mis
MINIO_USE_SSL=false

# JamboPay (M-Pesa B2C payouts)
JAMBOPAY_API_KEY=
JAMBOPAY_BASE_URL=https://sandbox.jambopay.co.ke/api/v1

# Perpay (Payroll & statutory remittance)
PERPAY_API_KEY=
PERPAY_BASE_URL=

# IPRS (KYC / national ID verification)
IPRS_API_KEY=
IPRS_BASE_URL=

# Africa's Talking (USSD + SMS)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SHORTCODE=

# Rate Limiting
RATE_LIMIT_RPM=100

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Webhook Signature Verification (HMAC-SHA256)
# Required in production to prevent spoofed callbacks
WEBHOOK_JAMBOPAY_SECRET=
WEBHOOK_PERPAY_SECRET=
