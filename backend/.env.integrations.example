# =============================================
# AMY MIS — Integration Provider Configuration
# =============================================
# All external integrations follow the Strategy pattern.
# To swap a vendor: change the *_PRIMARY_PROVIDER value.
# To disable a vendor: set *_ENABLED=false.
# To add redundancy: configure multiple providers; the primary
# is tried first, then fallbacks in registration order.
#
# ZERO-DOWNTIME SWITCHING: Change these env vars and restart.
# No code changes needed.
# =============================================

# ---- SMS PROVIDERS ----
# Primary provider controls which is tried first.
# Fallbacks are tried in order if the primary fails.
SMS_PRIMARY_PROVIDER=optimize        # "optimize" | "africastalking"
SMS_OPTIMIZE_ENABLED=true            # Set false to disable Optimize
SMS_AT_ENABLED=true                  # Set false to disable Africa's Talking

# Optimize SMS credentials
SMS_CLIENT_ID=
SMS_CLIENT_SECRET=
SMS_TOKEN_URL=
SMS_URL=
SMS_SENDER_ID=AMY-MIS
SMS_CALLBACK_URL=
SMS_TOKEN_EXPIRATION_TIME=3600

# Africa's Talking credentials
AT_API_KEY=
AT_USERNAME=sandbox
AT_SHORTCODE=
AT_BASE_URL=https://api.africastalking.com/version1

# ---- PAYMENT/PAYOUT PROVIDERS ----
# Switch from JamboPay to M-Pesa:
#   PAYMENT_JAMBOPAY_ENABLED=false
#   PAYMENT_MPESA_ENABLED=true
#   PAYMENT_PRIMARY_PROVIDER=mpesa
PAYMENT_PRIMARY_PROVIDER=jambopay    # "jambopay" | "mpesa"
PAYMENT_JAMBOPAY_ENABLED=true        # Set false to disable JamboPay
PAYMENT_MPESA_ENABLED=false          # Set true when M-Pesa is configured

# JamboPay credentials
JAMBOPAY_CLIENT_ID=
JAMBOPAY_CLIENT_SECRET=
JAMBOPAY_BASE_URL=

# M-Pesa Direct credentials (future)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BASE_URL=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# ---- PAYROLL PROVIDERS ----
PAYROLL_PRIMARY_PROVIDER=perpay      # "perpay"
PAYROLL_PERPAY_ENABLED=true          # Set false to disable PerPay

# PerPay credentials
PERPAY_CLIENT_ID=
PERPAY_CLIENT_SECRET=
PERPAY_BASE_URL=

# ---- IDENTITY/KYC PROVIDERS ----
# When IPRS is down, set IDENTITY_IPRS_ENABLED=false.
# The system will continue to work — KYC operations that
# require IPRS will return an error, but all other operations
# (crew CRUD, assignments, wallet, etc.) remain fully functional.
IDENTITY_PRIMARY_PROVIDER=iprs       # "iprs"
IDENTITY_IPRS_ENABLED=true           # Set false to disable IPRS

# IPRS credentials
IPRS_CLIENT_ID=
IPRS_CLIENT_SECRET=
IPRS_BASE_URL=
IPRS_TOKEN_ENDPOINT=

# ---- STORAGE PROVIDERS ----
STORAGE_PRIMARY_PROVIDER=minio       # "minio" | "s3"
STORAGE_MINIO_ENABLED=true           # Set false to disable MinIO

# MinIO credentials
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=amy-mis
MINIO_USE_SSL=false

# ---- WEBHOOK SECRETS ----
WEBHOOK_JAMBOPAY_SECRET=
WEBHOOK_PERPAY_SECRET=

# =============================================
# OPERATIONAL TUNING
# =============================================
# These settings control server performance and security limits.
# Defaults are tuned for moderate traffic. Override for high-throughput
# production or restricted staging environments.

# Database connection pool
DB_MAX_OPEN_CONNS=25          # Max simultaneous DB connections
DB_MAX_IDLE_CONNS=10          # Max idle connections in pool
DB_CONN_MAX_LIFE_MIN=5        # Max connection lifetime (minutes)
DB_CONN_MAX_IDLE_MIN=1        # Max idle time before closing (minutes)

# HTTP server limits
REQUEST_TIMEOUT_SEC=30        # Global request timeout (seconds)
MAX_REQUEST_BODY_MB=10        # Max request body size (megabytes)
RATE_LIMIT_RPM=100            # Rate limit: requests per minute per IP

# Export limits
CSV_EXPORT_MAX_ROWS=10000     # Max rows in CSV wallet export

